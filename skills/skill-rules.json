{
  "version": "1.0",
  "description": "Skill activation triggers for Claude Code. Controls when skills automatically suggest or block actions.",
  "skills": {
    "backend-patterns": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Backend architecture patterns and best practices",
      "promptTriggers": {
        "keywords": [
          "backend",
          "API",
          "endpoint",
          "controller",
          "service",
          "repository",
          "middleware",
          "route",
          "express",
          "fastapi",
          "django",
          "NestJS",
          "database",
          "ORM",
          "prisma",
          "REST",
          "GraphQL"
        ],
        "intentPatterns": [
          "(create|add|implement|build).*?(route|endpoint|API|controller|service|middleware)",
          "(fix|handle|debug).*?(error|exception|backend|API)",
          "(how to|best practice).*?(backend|route|controller|service|API)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "**/api/**/*.ts",
          "**/server/**/*.ts",
          "**/backend/**/*.ts",
          "**/routes/**/*.ts",
          "**/controllers/**/*.ts",
          "**/services/**/*.ts",
          "**/src/**/*Service.ts",
          "**/src/**/*Controller.ts"
        ],
        "pathExclusions": [
          "**/*.test.ts",
          "**/*.spec.ts"
        ],
        "contentPatterns": [
          "router\\.",
          "app\\.(get|post|put|delete|patch)",
          "export.*Controller",
          "export.*Service",
          "@Controller",
          "@Injectable"
        ]
      }
    },
    "frontend-patterns": {
      "type": "guardrail",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Frontend development patterns for React/Next.js/Vue",
      "promptTriggers": {
        "keywords": [
          "component",
          "react",
          "next.js",
          "nextjs",
          "vue",
          "frontend",
          "UI",
          "page",
          "modal",
          "dialog",
          "form",
          "styling",
          "CSS",
          "tailwind",
          "MUI",
          "shadcn"
        ],
        "intentPatterns": [
          "(create|add|make|build|update).*?(component|UI|page|modal|dialog|form)",
          "(how to|best practice).*?(component|react|frontend|UI)",
          "(style|design|layout).*?(component|UI|page)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "**/components/**/*.tsx",
          "**/pages/**/*.tsx",
          "**/app/**/*.tsx",
          "**/src/**/*.tsx",
          "**/frontend/**/*.tsx",
          "**/client/**/*.tsx"
        ],
        "pathExclusions": [
          "**/*.test.tsx",
          "**/*.spec.tsx",
          "**/node_modules/**"
        ],
        "contentPatterns": [
          "from 'react'",
          "from 'next",
          "useState|useEffect|useCallback",
          "export default function.*Page",
          "export.*Component"
        ]
      }
    },
    "coding-standards": {
      "type": "guardrail",
      "enforcement": "suggest",
      "priority": "medium",
      "description": "Universal coding standards and conventions",
      "promptTriggers": {
        "keywords": [
          "coding standard",
          "code style",
          "convention",
          "naming convention",
          "code quality",
          "lint",
          "format"
        ],
        "intentPatterns": [
          "(what|how).*?(naming|convention|standard|style)",
          "(review|check).*?(code quality|style|convention)"
        ]
      }
    },
    "security-review": {
      "type": "guardrail",
      "enforcement": "block",
      "priority": "critical",
      "description": "Security best practices and vulnerability prevention",
      "promptTriggers": {
        "keywords": [
          "security",
          "authentication",
          "authorization",
          "auth",
          "JWT",
          "token",
          "password",
          "encryption",
          "XSS",
          "SQL injection",
          "CSRF",
          "OWASP",
          "vulnerability"
        ],
        "intentPatterns": [
          "(add|implement|create).*?(auth|login|signup|security|encryption)",
          "(review|check|audit).*?(security|vulnerability|auth)",
          "(fix|prevent).*?(XSS|injection|CSRF|vulnerability)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "**/auth/**/*.ts",
          "**/auth/**/*.tsx",
          "**/middleware/auth*.ts",
          "**/security/**/*.ts"
        ],
        "contentPatterns": [
          "bcrypt|argon2",
          "jwt\\.sign|jwt\\.verify",
          "createCipheriv|createHash",
          "sanitize|escape|validate"
        ]
      },
      "blockMessage": "BLOCKED - Security Review Required\n\nREQUIRED ACTION:\n1. Use Skill tool: 'security-review'\n2. Review OWASP top 10 patterns\n3. Then retry this edit\n\nReason: Security-critical code detected"
    },
    "tdd-workflow": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Test-Driven Development workflow and patterns",
      "promptTriggers": {
        "keywords": [
          "test",
          "TDD",
          "unit test",
          "integration test",
          "e2e test",
          "testing",
          "jest",
          "vitest",
          "pytest",
          "coverage",
          "mock"
        ],
        "intentPatterns": [
          "(write|add|create|implement).*?(test|spec|coverage)",
          "(how to|best practice).*?(test|TDD|mock|coverage)",
          "(fix|debug).*?test"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "**/*.test.ts",
          "**/*.test.tsx",
          "**/*.spec.ts",
          "**/*.spec.tsx",
          "**/test_*.py",
          "**/*_test.py",
          "**/__tests__/**"
        ],
        "contentPatterns": [
          "describe\\(",
          "it\\(",
          "test\\(",
          "expect\\(",
          "jest\\.mock",
          "vi\\.mock"
        ]
      }
    },
