# YouTube Workflow Configuration Template
# Copy this file to your project directory and fill in the values

# YouTube Data API Key
YOUTUBE_API_KEY=your_youtube_api_key_here

# Apify API Key
APIFY_API_KEY=your_apify_api_key_here

# Email Recipients (comma-separated)
EMAIL_RECIPIENTS=user1@example.com,user2@example.com

# Gmail SMTP Settings (for sending emails)
GMAIL_SENDER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Optional: Apify Actor ID for captions
APIFY_ACTOR_ID=streamers/youtube-scraper

# Optional: Output directory for generated files
OUTPUT_DIR=./youtube_summaries

# How to get Gmail App Password:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Select "Mail" and "Other (Custom name)"
# 3. Enter "YouTube Workflow" as the app name
# 4. Copy the generated 16-character password
# 5. Paste it as GMAIL_APP_PASSWORD above
